rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== App Check 政策 ====================
    // 寫入(create/update/delete)一律要求 hasAppCheck()，
    // 也就是有效的 App Check token (reCAPTCHA v3 / debug token)。
    // 讀取維持公開，讓 SEO 爬蟲、初次未驗證使用者也能 fetch 資料。
    // 若需暫時關閉強制執行 (新版觀察期)，到 Firebase Console >
    // App Check > API > Cloud Firestore 切回「未強制」即可。

    // 歌曲集合 - 所有人可讀，僅管理員 + App Check 可寫
    match /songs/{songId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && hasAppCheck();
    }

    // 投票集合 - 所有人可讀取，新增需 App Check + 資料驗證
    match /votes/{voteId} {
      allow read: if true;
      allow create: if hasAppCheck() && isValidVote();
      allow delete: if isAdmin() && hasAppCheck();
    }

    // 歌曲建議集合 - 所有人可讀取，新增需 App Check + 內容驗證
    match /songSuggestions/{suggestionId} {
      allow read: if true;
      allow create: if hasAppCheck() && isValidSuggestion();
      allow update, delete: if isAdmin() && hasAppCheck();
    }

    // 標籤集合 - 所有人可讀，僅管理員 + App Check 可寫
    match /tags/{tagId} {
      allow read: if true;
      allow write: if isAdmin() && hasAppCheck();
    }

    // 歌曲標籤關聯集合 - 所有人可讀，僅管理員 + App Check 可寫
    match /songTags/{songTagId} {
      allow read: if true;
      allow write: if isAdmin() && hasAppCheck();
    }

    // 彈奏狀態集合 - 所有人可讀（即時同步），僅管理員 + App Check 可寫
    match /playedSongs/{playedId} {
      allow read: if true;
      allow write: if isAdmin() && hasAppCheck();
    }

    // 正在彈奏狀態集合 - 所有人可讀（即時同步），僅管理員 + App Check 可寫
    match /nowPlaying/{docId} {
      allow read: if true;
      allow write: if isAdmin() && hasAppCheck();
    }

    // QR Code 掃描記錄 - 讀公開（管理員看統計），寫需 App Check
    match /qrCodeScans/{scanId} {
      allow read: if true;
      allow create: if hasAppCheck();
      allow update, delete: if isAdmin();
    }

    // 互動集合 - 打賞和評分（讀公開，寫需 App Check + 資料驗證）
    match /interactions/{interactionId} {
      allow read: if true;
      allow create: if hasAppCheck() && isValidInteraction();
      allow update: if hasAppCheck() && isValidRatingUpdate();
      allow delete: if isAdmin() && hasAppCheck();
    }
    
    // 使用者集合 - 僅本人或管理員可讀寫
    match /users/{userId} {
      allow read: if request.auth != null && 
        (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && 
        (request.auth.uid == userId || isAdmin());
    }
    
    // ==================== 輔助函式 ====================

    // 檢查是否帶有效 App Check token
    // request.app 在已通過 App Check 驗證的請求中為 non-null
    // (Web SDK 自動帶上)。Firebase Console 必須啟用「強制執行」
    // 才會擋掉沒帶 token 的請求。
    function hasAppCheck() {
      return request.app != null;
    }

    // 檢查是否為管理員
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // 驗證投票資料有效性
    function isValidVote() {
      let data = request.resource.data;
      return data.keys().hasAll(['songId', 'sessionId', 'createdAt'])
        && data.songId is string
        && data.songId.size() > 0
        && data.songId.size() <= 100
        && data.sessionId is string
        && data.sessionId.size() > 0
        && data.sessionId.size() <= 100;
    }
    
    // 驗證歌曲建議資料有效性
    function isValidSuggestion() {
      let data = request.resource.data;
      return data.keys().hasAll(['title', 'artist', 'status', 'createdAt'])
        // 標題限制：必填，最長 100 字元
        && data.title is string
        && data.title.size() > 0
        && data.title.size() <= 100
        // 歌手限制：必填，最長 50 字元
        && data.artist is string
        && data.artist.size() > 0
        && data.artist.size() <= 50
        // 備註限制：選填，可以是 null 或字串，最長 500 字元
        && (!data.keys().hasAny(['notes']) || data.notes == null || (data.notes is string && data.notes.size() <= 500))
        // 推薦者限制：選填，可以是 null 或字串，最長 50 字元
        && (!data.keys().hasAny(['suggestedBy']) || data.suggestedBy == null || (data.suggestedBy is string && data.suggestedBy.size() <= 50))
        // 狀態必須是 pending
        && data.status == 'pending';
    }
    
    // 驗證互動資料有效性（打賞和評分）
    function isValidInteraction() {
      let data = request.resource.data;
      return data.keys().hasAll(['songId', 'type', 'sessionId', 'createdAt'])
        // songId 限制：必填字串
        && data.songId is string
        && data.songId.size() > 0
        && data.songId.size() <= 100
        // type 限制：必須是 tip 或 rating
        && data.type in ['tip', 'rating']
        // sessionId 限制：必填字串
        && data.sessionId is string
        && data.sessionId.size() > 0
        && data.sessionId.size() <= 100
        // tipType 限制：選填，必須是有效 emoji
        && (!data.keys().hasAny(['tipType']) || data.tipType == null || (data.tipType is string && data.tipType.size() <= 10))
        // rating 限制：選填，必須是 1-5
        && (!data.keys().hasAny(['rating']) || data.rating == null || (data.rating is int && data.rating >= 1 && data.rating <= 5));
    }
    
    // 驗證評分更新（只能更新自己的評分，且只能修改 rating 和 createdAt）
    function isValidRatingUpdate() {
      let data = request.resource.data;
      let existing = resource.data;
      return existing.type == 'rating'
        // sessionId 不能變更
        && data.sessionId == existing.sessionId
        // songId 不能變更
        && data.songId == existing.songId
        // type 不能變更
        && data.type == existing.type
        // rating 必須是 1-5
        && data.rating is int
        && data.rating >= 1
        && data.rating <= 5;
    }
  }
}
